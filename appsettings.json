{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "JWTSettings": {
    "Issuer": "RickToken",
    "Audience": "AuthClient",
    "TokenMinutesLifeTime": "10",
    "RefreshTokenDaysLifeTime": "10"
  },
  "Kestrel": {
    "Endpoints": {
      "Default": {
        "Url": "https://localhost:7200",
        "commandName": "Project",
        "dotnetRunMessages": true,
        "launchBrowser": true,
        "launchUrl": "swagger",
        "applicationUrl": "https://localhost:7200",
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        }
      }
    }
  }
}
